#include <stdio.h>

int main() {
    int numero;
    //Poderia usar while(numero =! 0)
    while (1) {
        printf("Digite um numero (0 para sair): ");
        scanf("%d", &numero);

        if (numero == 0)
            break;

        int temp = numero;
        int soma = 0;

        while (temp > 0) {
            soma += temp % 10;
            temp /= 10;
        }

        printf("Soma dos digitos de %d = %d\n", numero, soma);
    }

    return 0;
}
